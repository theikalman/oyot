{
  "$schema": "../gen/schemas/mobile-schema.json",
  "identifier": "mobile-default",
  "description": "Capability for the main window (Android and iOS)",
  "platforms": ["android", "iOS"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "**" }
      ]
    }
  ]
}
